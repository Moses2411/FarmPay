        completed_deliveries = db.query(Order).filter(
            Order.dispatch_rider_id == rider.id,
            Order.delivery_status == "confirmed"
        ).count()
        pending_deliveries = db.query(Order).filter(
            Order.dispatch_rider_id == rider.id,
            Order.delivery_status.in_(["assigned", "in_transit"])
