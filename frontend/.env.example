# FarmPay Frontend Environment Variables
# Copy this to .env and fill in your values

# ========================
# REQUIRED: API Base URL
# ========================
VITE_API_BASE_URL=http://localhost:8000
# For production: VITE_API_BASE_URL=https://your-backend-url.com

# ========================
# OPTIONAL: Mapbox Token
# ========================
# Get your token at: https://account.mapbox.com/access-tokens/
# Without this, the address picker will work in demo mode with limited features
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here